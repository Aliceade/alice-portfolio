# Substack RSS Feed (already correct — only change if your URL changes)
SUBSTACK_RSS_URL=https://untraditionalbos.substack.com/feed

# Cron job protection — generate any random string e.g. "x7mKpQ29"
# Used to secure the /api/rss-sync endpoint called by Vercel's scheduler
CRON_SECRET=REPLACE_WITH_ANY_RANDOM_STRING
